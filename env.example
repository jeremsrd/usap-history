# =============================================================================
# USAP History - Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# =============================================================================

# Base de données PostgreSQL (Supabase, Railway, ou local)
DATABASE_URL="postgresql://postgres:password@localhost:5432/usap_history"

# URL du site (pour les métadonnées SEO)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Optionnel : authentification admin (NextAuth ou Supabase Auth)
# NEXTAUTH_SECRET="votre-secret-ici"
# NEXTAUTH_URL="http://localhost:3000"
